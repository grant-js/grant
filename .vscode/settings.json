{
  "kiroAgent.configureMCP": "Disabled",

  // Format on save
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.formatOnType": false,

  // Set Prettier as default formatter
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // Enable ESLint auto-fix on save
  // Note: We let ESLint handle import ordering via import/order rule
  // TypeScript organizeImports is disabled to avoid conflicts
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },

  // File-specific settings
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[graphql]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },

  // ESLint settings
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  "eslint.workingDirectories": [
    "apps/api",
    "apps/web",
    "packages/@grantjs/core",
    "packages/@grantjs/client",
    "packages/@grantjs/database",
    "packages/@grantjs/schema",
    "packages/@grantjs/constants"
  ],

  // Prettier settings
  "prettier.requireConfig": true,
  "prettier.useEditorConfig": false,

  // TypeScript settings
  // organizeImportsOnSave disabled - ESLint import/order handles import organization
  "typescript.preferences.organizeImportsOnSave": false,
  "typescript.suggest.autoImports": true,

  // File associations
  "files.associations": {
    "*.graphql": "graphql",
    "*.gql": "graphql"
  }
}
