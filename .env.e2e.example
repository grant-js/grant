# =============================================================================
# Grant API – E2E Test Environment Variables
# =============================================================================
# These variables are used by the test runner (host side) to connect to the
# E2E Docker Compose services. Copy to .env.e2e and adjust if needed.
#
# The API container receives its own env via docker-compose.e2e.yml.
# =============================================================================

# Base URL of the API container (exposed by docker-compose.e2e.yml)
E2E_API_BASE_URL=http://localhost:4000

# Database connection for the test runner (host → E2E Postgres on port 5433)
# Used by DB helpers to read verification/invitation tokens
E2E_DB_URL=postgresql://grant_user:grant_password@localhost:5433/grant_e2e

# Redis connection (host → E2E Redis on port 6380) – optional, for debugging
E2E_REDIS_HOST=localhost
E2E_REDIS_PORT=6380
E2E_REDIS_PASSWORD=grant_redis_password
