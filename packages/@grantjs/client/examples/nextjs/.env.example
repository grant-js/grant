# Grant API base URL (required for permission checks)
NEXT_PUBLIC_GRANT_API_URL=http://localhost:4000

# Grant web app URL (required for signInWithProjectApp: entry page at /auth/project)
NEXT_PUBLIC_GRANT_FRONTEND_URL=http://localhost:3000

# Example app origin (callback = origin + /example/callback). Default: http://localhost:3004
NEXT_PUBLIC_EXAMPLE_APP_ORIGIN=http://localhost:3004
