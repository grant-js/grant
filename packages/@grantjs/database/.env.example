DB_URL=postgresql://grant_user:grant_password@localhost:5432/grant_db
# System user ID for internal operations (used during database seeding)
# Default: 00000000-0000-0000-0000-000000000000
# This should match the SYSTEM_USER_ID configured in apps/api/.env
SYSTEM_USER_ID=00000000-0000-0000-0000-000000000000
